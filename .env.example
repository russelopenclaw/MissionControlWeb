# Mission Control Web App - Environment Variables
# Copy this file to .env.local and fill in your values

# Authentication
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-must-be-at-least-32-characters"
AUTH_PASSWORD="your-dashboard-password-here"

# PostgreSQL Database
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://alfred:AlfredDB2026Secure@localhost:5432/mission_control"

# Mission Control API (optional, for future features)
MISSION_CONTROL_API="http://localhost:8765"
